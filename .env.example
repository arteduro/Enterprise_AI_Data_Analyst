# ============================================================
# Enterprise AI Data Analyst
# Archivo de ejemplo de variables de entorno
# Copie este archivo como ".env" y complete los valores.
# ============================================================

# ============================================================
# INFORMACIÓN DEL PROYECTO
# ============================================================

APP_NAME=Enterprise AI Data Analyst
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# ============================================================
# PROVEEDOR DE IA
# Opciones:
# google
# openai
# anthropic
# azure
# ollama
# ============================================================

MODEL_PROVIDER=google

# ============================================================
# GOOGLE GEMINI
# ============================================================

# Obtenga una API Key gratuita en:
# https://aistudio.google.com/app/apikey

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Modelo recomendado
GEMINI_MODEL=gemini-2.5-flash

# Alternativas
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

THINKING_LEVEL=high

# ============================================================
# OPENAI (Opcional)
# ============================================================

OPENAI_API_KEY=

# ============================================================
# ANTHROPIC (Opcional)
# ============================================================

ANTHROPIC_API_KEY=

# ============================================================
# AZURE OPENAI (Opcional)
# ============================================================

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ============================================================
# LANGSMITH (Opcional)
# ============================================================

LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=Enterprise_AI_Data_Analyst
LANGCHAIN_TRACING_V2=true

# ============================================================
# BASE DE DATOS
# ============================================================

DATABASE_URL=sqlite:///database.db

# PostgreSQL (ejemplo)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/enterprise_ai

# ============================================================
# VECTOR DATABASE (RAG)
# ============================================================

VECTOR_DB=chromadb
CHROMA_PATH=./database/chroma

# ============================================================
# EMBEDDINGS
# ============================================================

EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/text-embedding-004

# ============================================================
# MEMORIA DEL AGENTE
# ============================================================

MEMORY_PATH=./memory

# ============================================================
# API
# ============================================================

API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# STREAMLIT
# ============================================================

STREAMLIT_SERVER_PORT=8501

# ============================================================
# SEGURIDAD
# ============================================================

SECRET_KEY=CHANGE_ME

# ============================================================
# DIRECTORIOS
# ============================================================

UPLOAD_FOLDER=uploads
REPORT_FOLDER=reports
LOG_FOLDER=logs
ARTIFACT_FOLDER=artifacts

# ============================================================
# LOGS
# ============================================================

LOG_LEVEL=INFO

# ============================================================
# MACHINE LEARNING
# ============================================================

RANDOM_STATE=42

# ============================================================
# CACHE
# ============================================================

CACHE_ENABLED=true

# ============================================================
# DASHBOARD
# ============================================================

DEFAULT_THEME=light

# ============================================================
# REPORTES
# ============================================================

DEFAULT_REPORT_LANGUAGE=es

# ============================================================
# AGENTES
# ============================================================

MAX_AGENT_ITERATIONS=20

# ============================================================
# RAG
# ============================================================

TOP_K_DOCUMENTS=5

# ============================================================
# OCR
# ============================================================

OCR_LANGUAGE=spa

# ============================================================
# EXPORTACIÓN
# ============================================================

EXPORT_FORMAT=pdf